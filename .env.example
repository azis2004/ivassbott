# Token bot dari @BotFather di Telegram
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat ID admin (kamu) — dapatkan dengan chat ke @userinfobot
ADMIN_CHAT_ID=123456789

# Cookies iVAS SMS dalam format JSON
# Cara ambil:
# 1. Login ke https://www.ivasms.com
# 2. Buka DevTools (F12) → Application → Cookies → www.ivasms.com
# 3. Copy semua cookies ke format JSON seperti di bawah:
# Format array: [{"name":"session","value":"xxx",...}, ...]
# Format dict:  {"session":"xxx","_ga":"xxx",...}
IVASMS_COOKIES={"session":"your_session_value_here"}

# Interval polling iVAS SMS (detik) — default 30 detik
POLL_INTERVAL=30

# Path database SQLite (opsional, default: bot_data.db)
DB_PATH=bot_data.db
